# Maintainer: devcxl <64475363+devcxl@users.noreply.github.com>
# Contributor: devcxl <64475363+devcxl@users.noreply.github.com>

pkgname=recordly
pkgver=1.0.0
pkgrel=1
pkgdesc="开源屏幕录制与回放工具 — 支持鼠标轨迹记录、多轨道时间线编辑、光标特效和 MP4/GIF/APNG 导出"
arch=('any')
url="https://github.com/devcxl/recordly"
license=('MIT')
depends=(
    'python>=3.10'
    'python-pyqt5'
    'python-pillow'
    'python-numpy'
    'python-mss'
    'ffmpeg'
    'portaudio'
)
makedepends=(
    'python-build'
    'python-installer'
    'python-wheel'
    'python-setuptools'
    'python-pip'
)
optdepends=(
    'python-pynput: 鼠标轨迹记录'
    'python-sounddevice: 音频录制'
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/devcxl/recordly/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')
validpgpkeys=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver"
    python -m build --wheel --no-isolation
}

package() {
    cd "$srcdir/$pkgname-$pkgver"
    python -m installer --destdir="$pkgdir" dist/*.whl

    # 安装 .desktop 入口
    install -Dm644 debian/recordly.desktop \
        "$pkgdir/usr/share/applications/recordly.desktop"

    # 安装图标
    install -Dm644 resources/icons/recordly.svg \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/recordly.svg"

    # 安装 AppStream 元数据
    install -Dm644 debian/io.github.devcxl.recordly.appdata.xml \
        "$pkgdir/usr/share/metainfo/io.github.devcxl.recordly.appdata.xml"
}
