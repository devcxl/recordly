# Maintainer: devcxl <64475363+devcxl@users.noreply.github.com>
# Contributor: devcxl <64475363+devcxl@users.noreply.github.com>

pkgname=recordly
pkgver=1.0.4
pkgrel=1
pkgdesc="开源屏幕录制与回放工具 — 支持鼠标轨迹记录、多轨道时间线编辑、光标特效和 MP4/GIF/APNG 导出"
arch=('any')
url="https://github.com/devcxl/recordly"
license=('MIT')
depends=(
    'ffmpeg'
    'portaudio'
)
makedepends=(
    'python>=3.10'
    'python-build'
    'python-installer'
    'python-wheel'
    'python-setuptools'
    'python-pip'
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/devcxl/recordly/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')
validpgpkeys=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver"
    pip install --break-system-packages pyinstaller
    pip install --break-system-packages .
    pyinstaller recordly.spec --distpath="$srcdir/dist" --workpath="$srcdir/build"
}

package() {
    install -Dm755 "$srcdir/dist/recordly" "$pkgdir/usr/bin/recordly"
    install -Dm644 "$srcdir/$pkgname-$pkgver/debian/recordly.desktop" \
        "$pkgdir/usr/share/applications/recordly.desktop"
    install -Dm644 "$srcdir/$pkgname-$pkgver/resources/icons/recordly.svg" \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/recordly.svg"
    install -Dm644 "$srcdir/$pkgname-$pkgver/debian/io.github.devcxl.recordly.appdata.xml" \
        "$pkgdir/usr/share/metainfo/io.github.devcxl.recordly.appdata.xml"
}
